# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/
nosetests.xml
test-results/
cypress/videos/
cypress/screenshots/
cypress/downloads/

# -----------------------------------------------------------------------------
# CI / CD
# -----------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.backup
.vagrant/

# -----------------------------------------------------------------------------
