# .env.example — safe to commit, shows required variables
# Copy this file to .env and fill in your real values.
# Never commit .env — it is already listed in .gitignore.

# ── Production bot (wikidata.org) ────────────────────────────────────────────
# Create at: https://www.wikidata.org/wiki/Special:BotPasswords
# Username format: YourWikidataAccount@BotName
WD_USERNAME="YourAccount@BotName"
WD_PASSWORD="your_bot_password_here"

# ── Sandbox bot (test.wikidata.org) — safe for testing ───────────────────────
# Create at: https://test.wikidata.org/wiki/Special:BotPasswords
# Same format as above — bot passwords are site-specific
WD_TEST_USERNAME="YourAccount@BotName"
WD_TEST_PASSWORD="your_test_bot_password_here"

# ── API User-Agent ────────────────────────────────────────────────────────────
# Wikimedia policy requires a descriptive User-Agent with contact info.
# Requests without a proper User-Agent may be blocked (HTTP 403).
# Format: ScriptName/version (project-url; contact@email.com) python-requests
WD_USER_AGENT="wikidata-item-creator/1.0 (https://your-project-url; your@email.com) python-requests"
